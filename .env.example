# ============================================================
# SISPOS — Environment Variables
# Copy file ini menjadi .env dan isi semua nilainya
# JANGAN commit file .env ke git
# ============================================================

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost

# JWT
JWT_SECRET=ganti_dengan_random_string_min_32_karakter
JWT_REFRESH_SECRET=ganti_dengan_random_string_lain_min_32_karakter
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_PASSWORD=ganti_password_db_kamu
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@sispos-db:5432/sispos

# Redis
REDIS_PASSWORD=ganti_password_redis_kamu
REDIS_URL=redis://:${REDIS_PASSWORD}@sispos-redis:6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google Cloud Speech-to-Text
GOOGLE_CLOUD_PROJECT_ID=nama-project-google-cloud-kamu
GOOGLE_APPLICATION_CREDENTIALS=/app/gcloud-key.json

# WhatsApp (Fonnte)
FONNTE_API_KEY=isi_api_key_fonnte
FONNTE_SENDER=628xxxxxxxxxx

# Enkripsi kolom medis (UU PDP) — generate dengan: openssl rand -hex 32
APP_ENCRYPTION_KEY=ganti_dengan_64_karakter_hex_random

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost/api
VITE_WS_URL=http://localhost
