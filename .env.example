# =============================================================
# SISPOS — Environment Variables Template
# Salin file ini ke .env dan isi nilai yang sesuai.
# JANGAN commit file .env ke git.
# =============================================================

# PostgreSQL
DATABASE_URL=postgresql://sispos_user:CHANGEME@sispos-db:5432/sispos
POSTGRES_DB=sispos
POSTGRES_USER=sispos_user
POSTGRES_PASSWORD=CHANGEME

# Redis
REDIS_URL=redis://:CHANGEME@sispos-redis:6379
REDIS_PASSWORD=CHANGEME

# JWT (minimal 32 karakter masing-masing)
JWT_SECRET=CHANGEME_STRONG_SECRET_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGEME_STRONG_REFRESH_SECRET_MINIMUM_32_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost

# Enkripsi kolom medis (UU PDP No. 27/2022)
# Generate dengan: openssl rand -hex 32
APP_ENCRYPTION_KEY=CHANGEME_64_CHAR_HEX_STRING_GENERATE_WITH_OPENSSL

# OpenAI (Phase 4)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Fonnte WhatsApp (Phase 1)
FONNTE_API_KEY=
FONNTE_SENDER=

# Google Cloud STT — mount file JSON dan set path (Phase 3)
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json
GOOGLE_CLOUD_PROJECT_ID=
